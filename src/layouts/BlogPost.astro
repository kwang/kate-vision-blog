---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 800px;
				max-width: calc(100% - 2em);
				margin: auto;
			}
			.prose {
				font-size: 1.15rem;
				line-height: 1.8;
				color: #374151; /* Softer slate gray for readable long-form text */
				padding: 1em 0;
			}
			.prose p {
				margin-bottom: 1.5em;
			}
			.title {
				margin-bottom: 2em;
				padding: 1.5em 0;
				text-align: center;
				line-height: 1.3;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				font-size: 2.2rem;
				font-weight: 700;
				color: #111827;
			}
			.date {
				margin-bottom: 1em;
				color: #6b7280;
				font-size: 0.95rem;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.last-updated-on {
				font-style: italic;
			}
			hr {
				border: none;
				border-top: 1px solid #e5e7eb;
				margin: 2em 0;
			}
			/* Styling code blocks or quotes in blog posts */
			.prose blockquote {
				border-left: 4px solid var(--accent);
				background: #f9fafb;
				padding: 1rem 1.5rem;
				border-radius: 0 8px 8px 0;
				margin: 1.5rem 0;
				font-style: italic;
				color: #4b5563;
			}
		</style>
	
		<!-- Schema.org JSON-LD for Google Rich Snippets -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BlogPosting",
			"headline": title,
			"description": description,
			"datePublished": pubDate.toISOString(),
			"dateModified": updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
			"author": [{
				"@type": "Person",
				"name": "Kate (Engineering Manager) & Qi (AI)",
				"url": "https://kate-vision-blog.vercel.app/about"
			}]
		})} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	
		<script is:inline>
			document.addEventListener('DOMContentLoaded', () => {
				const prose = document.querySelector('.prose');
				if (!prose) return;
				
				let isChineseSection = false;
				Array.from(prose.children).forEach(node => {
					if(node.classList && node.classList.contains('title')) return;
					
					if (node.tagName === 'HR') {
						let nextNode = node.nextElementSibling;
						if (nextNode && (nextNode.textContent.includes('Chinese') || nextNode.textContent.includes('中文') || nextNode.textContent.includes('Translation'))) {
							isChineseSection = true;
							node.classList.add('lang-zh');
							return;
						}
					}
					
					if (isChineseSection) {
						node.classList.add('lang-zh');
					} else {
						node.classList.add('lang-en');
					}
				});
			});
		</script>

	</body>
</html>
